API_KEYS=
# Hostname Traefik uses in Host(`…`) — must match an A/AAAA record pointing at this server
PUBLIC_HOST=ffmpeg.v1su4.dev
# Docker network the Traefik container is on (see README). Used with docker-compose.traefik.yml
TRAEFIK_NETWORK=traefik
API_HOST=0.0.0.0
API_PORT=3200
CORS_ORIGINS=*
# Docker (Ubuntu image): use absolute paths. Local dev can use `ffmpeg` / `ffprobe` on PATH.
FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe
FFEDIT_PATH=ffedit
FFGAC_PATH=ffgac
METRICS_TOKEN=
MAX_UPLOAD_SIZE_MB=500
